# Copy this file to .env and fill in your own values.

# Claude model used for chat answers and routing
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT=120

# Optional: model used by the agent's router node (defaults to CLAUDE_MODEL's value)
ROUTING_MODEL=claude-sonnet-4-6

# Neo4j connection (matches docker-compose.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
